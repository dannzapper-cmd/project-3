# InvForge — Azure Container Apps deploy variables (PR-10 template).
# Copy to a local, git-ignored file and fill in YOUR values. Never commit real
# subscription IDs, registries, or secrets.

# --- Required deploy parameters (placeholders only) ---
SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
RESOURCE_GROUP=invforge-rg
LOCATION=eastus
APP_NAME=invforge-ai-ops
ENVIRONMENT_NAME=invforge-env
# Azure Container Registry login server, e.g. myregistry.azurecr.io
REGISTRY_SERVER=myregistry.azurecr.io
# Full image URI, e.g. myregistry.azurecr.io/invforge/ai-ops:latest
IMAGE_URI=REGISTRY_SERVER/invforge/ai-ops:latest

# --- Runtime config injected into the container (non-secret) ---
INVFORGE_ENV=cloud
INVFORGE_DEMO_MODE=true
INVFORGE_ALLOW_MUTATIONS=false
LOG_LEVEL=INFO

# --- Secrets ---
# Store sensitive values as Container Apps secrets or in Azure Key Vault. Only
# the secret NAME is referenced (secretRef) in the template; never the value.
# INVENTREE_API_TOKEN_SECRET=inventree-api-token
