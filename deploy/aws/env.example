# InvForge — AWS ECS/Fargate deploy variables (PR-10 template).
# Copy to a local, git-ignored file and fill in YOUR values. Never commit real
# account IDs, ARNs, or secrets.

# --- Required deploy parameters (placeholders only) ---
ACCOUNT_ID=000000000000
REGION=us-east-1
# ECR image URI, e.g. 000000000000.dkr.ecr.us-east-1.amazonaws.com/invforge/ai-ops:latest
IMAGE_URI=ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/invforge/ai-ops:latest

# IAM roles (create with least privilege; do NOT use AdministratorAccess):
#   EXECUTION_ROLE_ARN: pulls the image + writes logs (AmazonECSTaskExecutionRolePolicy)
#   TASK_ROLE_ARN: the app's own runtime permissions (minimal; often none for demo)
EXECUTION_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/invforge-ecs-execution
TASK_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/invforge-ai-ops-task

# Networking (for the ECS service): provide your own subnet/security-group IDs.
SUBNET_IDS=subnet-REPLACE
SECURITY_GROUP_ID=sg-REPLACE

# --- Runtime config injected into the container (non-secret) ---
INVFORGE_ENV=cloud
INVFORGE_DEMO_MODE=true
INVFORGE_ALLOW_MUTATIONS=false
LOG_LEVEL=INFO

# --- Secrets ---
# Store sensitive values in AWS Secrets Manager and reference the ARN in the
# task definition `secrets` block. Only the NAME/ARN goes here, never the value.
# INVENTREE_API_TOKEN_SECRET_ARN=arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:invforge/inventree-api-token
