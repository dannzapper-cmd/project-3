# InvForge — GCP Cloud Run deploy variables (PR-10 template).
# Copy to a local, git-ignored file (e.g. deploy/gcp/.env) and fill in YOUR
# values. Never commit real project IDs, secrets, or billing identifiers.

# --- Required deploy parameters (placeholders only) ---
PROJECT_ID=your-gcp-project-id
REGION=us-central1
SERVICE_NAME=invforge-ai-ops
# Artifact Registry image URI, e.g.
# us-central1-docker.pkg.dev/your-gcp-project-id/invforge/ai-ops:latest
IMAGE_URI=REGION-docker.pkg.dev/PROJECT_ID/invforge/ai-ops:latest

# Optional: dedicated least-privilege runtime service account.
SA_EMAIL=invforge-ai-ops@PROJECT_ID.iam.gserviceaccount.com

# --- Runtime config injected into the container (non-secret) ---
INVFORGE_ENV=cloud
INVFORGE_DEMO_MODE=true
INVFORGE_ALLOW_MUTATIONS=false
LOG_LEVEL=INFO

# --- Secrets ---
# Do NOT put secret VALUES here. Store them in Secret Manager and reference by
# name in service.template.yaml (secretKeyRef). This is only the secret NAME.
# INVENTREE_API_TOKEN_SECRET=invforge-inventree-api-token
