INVENTREE_BASE_URL=http://inventree.localhost:8080
INVENTREE_API_TOKEN=replace-me
INVENTREE_USERNAME=admin
INVENTREE_PASSWORD=replace-me-local-only
INVFORGE_DATA_DIR=data
INVFORGE_API_PORT=8001
INVENTREE_TIMEOUT_SECONDS=10

# PR-10 runtime mode (see docs/deployment-contract.md).
# INVFORGE_ENV: local | ci | demo | cloud
#   local/ci  -> mutations allowed, strict health (default for development)
#   demo/cloud -> read-only by default, mutations blocked, health stays 200
INVFORGE_ENV=local
# Override the per-env defaults if needed. Leave unset to use env-derived
# defaults. NEVER set INVFORGE_ALLOW_MUTATIONS=true on a public deployment.
# INVFORGE_DEMO_MODE=false
# INVFORGE_ALLOW_MUTATIONS=true
# PORT is injected by Cloud Run / Container Apps / Fargate. The container
# entrypoint binds uvicorn to ${PORT:-8001}.
# PORT=8001
