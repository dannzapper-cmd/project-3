# InvForge — InvenTree environment variables (safe placeholders only)
# Copy to .env and adjust for local use: cp .env.example .env
#
# Full configuration reference:
# https://docs.inventree.org/en/stable/start/config/
#
# First-time setup (after docker-up):
#   cd app && docker compose run --rm -T inventree-server invoke update
#
# Create admin user (optional):
#   cd app && docker compose run --rm inventree-server invoke superuser

COMPOSE_PROJECT_NAME=invforge-inventree

# Pin to a specific stable release (do not use :latest in production)
INVENTREE_TAG=1.3.2

INVENTREE_SITE_URL="http://inventree.localhost"
INVENTREE_WEB_PORT=8000
INVENTREE_HTTP_PORT=8080
INVENTREE_HTTPS_PORT=8443

INVENTREE_USE_X_FORWARDED_HOST=True
INVENTREE_USE_X_FORWARDED_PORT=True
INVENTREE_USE_X_FORWARDED_PROTO=True

# Local persistent data directory (relative to app/)
INVENTREE_EXT_VOLUME=./inventree-data

INVENTREE_LOG_LEVEL=WARNING
INVENTREE_PLUGINS_ENABLED=True
INVENTREE_AUTO_UPDATE=True

# Uncomment and set to auto-create an admin account on first run
#INVENTREE_ADMIN_USER=admin
#INVENTREE_ADMIN_PASSWORD=change-me-local-only
#INVENTREE_ADMIN_EMAIL=admin@example.com

# PostgreSQL (InvenTree base stack)
INVENTREE_DB_ENGINE=postgresql
INVENTREE_DB_NAME=inventree
INVENTREE_DB_HOST=inventree-db
INVENTREE_DB_PORT=5432
INVENTREE_DB_USER=invforge_pguser
INVENTREE_DB_PASSWORD=invforge_pgpassword_change_me

# Redis cache
INVENTREE_CACHE_ENABLED=True
INVENTREE_CACHE_HOST=inventree-cache
INVENTREE_CACHE_PORT=6379

INVENTREE_GUNICORN_TIMEOUT=90
